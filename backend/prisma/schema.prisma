generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Cuenta de acceso a la aplicación. Puede estar vinculada a un empleado.
model User {
  id                  String            @id @default(uuid())
  email               String            @unique
  password            String
  role                Role              @default(EMPLOYEE)
  resetToken          String?
  resetExpires        DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  employeeId          String?           @unique
  managedDepartmentId String?
  approvals           ApprovalHistory[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  employee            Employee?         @relation(fields: [employeeId], references: [id])
  managedDepartment   Department?       @relation("DepartmentManagers", fields: [managedDepartmentId], references: [id])
}

/// Departamento de la empresa. Define un color para el calendario de equipo.
model Department {
  id        String     @id @default(uuid())
  name      String     @unique
  color     String     @default("#3b82f6")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  employees Employee[]
  managers  User[]     @relation("DepartmentManagers")
}

/// Empleado de la empresa.
model Employee {
  id                 String              @id @default(uuid())
  firstName          String
  lastName           String
  email              String              @unique
  hireDate           DateTime
  annualVacationDays Int                 @default(22)
  status             EmployeeStatus      @default(ACTIVE)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  departmentId       String
  color              String              @default("#3b82f6")
  positionId         String
  department         Department          @relation(fields: [departmentId], references: [id])
  position           Position            @relation(fields: [positionId], references: [id])
  user               User?
  vacationCycles     VacationCycle[]
  exclusionsA        VacationExclusion[] @relation("ExclusionsA")
  exclusionsB        VacationExclusion[] @relation("ExclusionsB")
  vacationRequests   VacationRequest[]
  absences           Absence[]
}

/// Solicitud de vacaciones de un empleado.
model VacationRequest {
  id            String            @id @default(uuid())
  startDate     DateTime
  endDate       DateTime
  daysRequested Int
  reason        String?
  status        RequestStatus     @default(PENDING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  employeeId    String
  chargedToYear Int?
  approvals     ApprovalHistory[]
  employee      Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
  @@index([chargedToYear])
}

/// Historial de decisiones (aprobación/rechazo) sobre una solicitud.
model ApprovalHistory {
  id         String           @id @default(uuid())
  decision   ApprovalDecision
  comment    String?
  createdAt  DateTime         @default(now())
  requestId  String
  approverId String
  approver   User             @relation(fields: [approverId], references: [id])
  request    VacationRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

/// Notificación in-app / email.
model Notification {
  id        String   @id @default(uuid())
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Feriado / día no laborable.
model Holiday {
  id              String   @id @default(uuid())
  name            String
  date            DateTime @unique
  deductsVacation Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// Configuración global del sistema (singleton).
model SystemConfig {
  id                   String   @id @default("singleton")
  seniorityTiers       Json     @default("[{\"days\": 7, \"maxYears\": 0.5, \"minYears\": 0}, {\"days\": 14, \"maxYears\": 1, \"minYears\": 0.5}, {\"days\": 14, \"maxYears\": 5, \"minYears\": 1}, {\"days\": 21, \"maxYears\": 10, \"minYears\": 5}, {\"days\": 21, \"maxYears\": 15, \"minYears\": 10}, {\"days\": 28, \"maxYears\": 20, \"minYears\": 15}, {\"days\": 35, \"maxYears\": 99, \"minYears\": 20}]")
  minAdvanceNoticeDays Int      @default(7)
  maxOverlapPercent    Int      @default(50)
  maxOverlapCount      Int      @default(0)
  updatedAt            DateTime @updatedAt
  allowAdvanceRequest  Boolean  @default(true)
  maxAdvanceDays       Int      @default(0)
  nextYearOpenDay      Int      @default(1)
  nextYearOpenMonth    Int      @default(10)
  allowCarryOver       Boolean  @default(true)
  maxCarryOverDays     Int      @default(0)
}

/// Ciclo anual de vacaciones por empleado.
/// Registra el saldo asignado y si el período está abierto para recibir solicitudes.
model VacationCycle {
  id         String    @id @default(uuid())
  year       Int
  annualDays Int
  carryOver  Int       @default(0)
  isOpen     Boolean   @default(false)
  openedAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, year])
  @@index([year])
  @@index([employeeId])
}

/// Pareja de empleados que no pueden superponer sus vacaciones.
model VacationExclusion {
  id          String   @id @default(uuid())
  employeeAId String
  employeeBId String
  createdAt   DateTime @default(now())
  employeeA   Employee @relation("ExclusionsA", fields: [employeeAId], references: [id], onDelete: Cascade)
  employeeB   Employee @relation("ExclusionsB", fields: [employeeBId], references: [id], onDelete: Cascade)

  @@unique([employeeAId, employeeBId])
}

/// Límite máximo de vacaciones simultáneas para un cargo/posición específico.
model PositionOverlapLimit {
  id           String   @id @default(uuid())
  maxEmployees Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  positionId   String   @unique
  position     Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
}

/// Cargo (Position) de la empresa.
model Position {
  id           String                @id @default(uuid())
  name         String                @unique
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  employees    Employee[]
  overlapLimit PositionOverlapLimit?
}

/// Registra inasistencias, licencias médicas y otros estados especiales de un empleado.
model Absence {
  id         String        @id @default(uuid())
  startDate  DateTime
  endDate    DateTime
  daysCount  Int
  type       AbsenceType
  reason     String?
  status     RequestStatus @default(APPROVED)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  employeeId String
  employee   Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([type])
  @@index([startDate, endDate])
}

/// Registro de auditoría de cambios.
model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  @@index([entity])
  @@index([userId])
}

enum Role {
  ADMIN
  EMPLOYEE
  MANAGER
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ApprovalDecision {
  APPROVED
  REJECTED
}

enum AbsenceType {
  DESCUENTO_DIA
  BAJA_ENFERMEDAD
  TRAMITE_PERSONAL
  GUARDIA
  DIA_ESTUDIO
  OTHER
}
