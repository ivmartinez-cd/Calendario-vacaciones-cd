# --- Servidor ---
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173

# --- Base de datos (PostgreSQL) ---
DATABASE_URL="postgresql://vacasync:vacasync@localhost:5432/vacasync?schema=public"

# --- JWT ---
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# --- Email (SMTP). En desarrollo se usa Ethereal automáticamente si se deja vacío ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="VacaSync <no-reply@vacasync.com>"

# URL del frontend para enlaces de email (reset de contraseña, etc.)
FRONTEND_URL=http://localhost:5173
